{
  "name": "backend",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "make:module": "bun scripts/make-module.ts",
    "db:make": "bun scripts/make-migration.ts",
    "db:migrate": "bun scripts/migrate.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "vercel-build": "esbuild src/vercel.ts --bundle --platform=node --target=node18 --format=esm --outfile=api/index.mjs --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/lib-storage": "^3.1038.0",
    "@better-auth/kysely-adapter": "^1.2.10",
    "@hono/node-server": "^2.0.0",
    "better-auth": "^1.6.9",
    "hono": "^4.12.15",
    "kysely": "^0.28.16",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "esbuild": "^0.28.0"
  }
}